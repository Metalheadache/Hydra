# ─── Hydra Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables use the HYDRA_ prefix.

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Anthropic (default)
HYDRA_API_KEY=sk-ant-...
HYDRA_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
HYDRA_BRAIN_MODEL=anthropic/claude-sonnet-4-6
HYDRA_POST_BRAIN_MODEL=anthropic/claude-sonnet-4-6

# OpenAI
# HYDRA_API_KEY=sk-...
# HYDRA_DEFAULT_MODEL=gpt-4o
# HYDRA_BRAIN_MODEL=gpt-4o
# HYDRA_POST_BRAIN_MODEL=gpt-4o

# Azure OpenAI
# HYDRA_API_KEY=<azure-key>
# HYDRA_API_BASE=https://<your-resource>.openai.azure.com
# HYDRA_DEFAULT_MODEL=azure/gpt-4o

# Local Ollama (no API key needed)
# HYDRA_API_BASE=http://localhost:11434
# HYDRA_DEFAULT_MODEL=ollama/llama3
# HYDRA_BRAIN_MODEL=ollama/llama3
# HYDRA_POST_BRAIN_MODEL=ollama/llama3

# Google Gemini
# HYDRA_API_KEY=<gemini-api-key>
# HYDRA_DEFAULT_MODEL=gemini/gemini-1.5-pro

# ─── Web Search (optional — for research agents) ──────────────────────────────
# HYDRA_SEARCH_BACKEND=brave          # brave | tavily | serpapi
# HYDRA_SEARCH_API_KEY=BSA...         # Brave Search API key

# ─── Execution Limits ────────────────────────────────────────────────────────
HYDRA_MAX_CONCURRENT_AGENTS=5
HYDRA_PER_AGENT_TIMEOUT_SECONDS=60
HYDRA_TOTAL_TASK_TIMEOUT_SECONDS=300
HYDRA_TOTAL_TOKEN_BUDGET=100000

# ─── Output ──────────────────────────────────────────────────────────────────
HYDRA_OUTPUT_DIRECTORY=./hydra_output
