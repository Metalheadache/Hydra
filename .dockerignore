# Version control
.git
.gitignore

# Python caches
**/__pycache__
**/*.py[cod]
**/*.pyo
.mypy_cache
.ruff_cache
.pytest_cache
*.egg-info
dist/
build/
.eggs/

# Frontend build artifacts and deps (frontend/dist is rebuilt in Stage 1)
frontend/node_modules
frontend/dist

# Tests and development files
tests/
examples/
*.md
!README.md

# Environment and secrets
.env
.env.*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore

# Hydra output from local dev runs
hydra_output/
